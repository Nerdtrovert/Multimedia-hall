PORT=5000
# Comma-separated frontend origins allowed by CORS.
# Add your tunnel or deployed frontend URL here when testing outside localhost.
FRONTEND_URL=http://localhost:3000

# Public backend origin(s), used when generating absolute links.
# Keep localhost for local dev; add tunnel or deployed backend URLs as needed.
BACKEND_URL=http://localhost:5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=auditorium_db
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# Email (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=Auditorium System <your_email@gmail.com>
# Use relative paths so mail buttons follow the configured frontend origin.
MAIL_LOGIN_URL=/login
MAIL_DASHBOARD_URL=/user/dashboard
MAIL_ADMIN_URL=/admin/requests
MAIL_BOOKINGS_URL=/user/my-bookings

# Post-event report reminders
POST_REPORT_REMINDER_CRON=0 14 * * *
POST_REPORT_REMINDER_TZ=Asia/Kolkata
# Set true to run once when server starts (useful for testing)
POST_REPORT_REMINDER_RUN_ON_STARTUP=false
# If the app is behind a proxy/load-balancer (terminating TLS), set TRUST_PROXY=true
# so req.protocol correctly reflects https when generating absolute URLs.
TRUST_PROXY=false

# Supervisor seed account (maintenance/emergency only)
SUPERVISOR_NAME=Emergency Supervisor
SUPERVISOR_EMAIL=supervisor@auditorium.com
SUPERVISOR_PASSWORD=ChangeThisSupervisorPassword

# Optional seed overrides
SEED_ADMIN_USERNAME=nes-admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeAdminPassword123!
SEED_COLLEGE_PASSWORD=ChangeCollegePassword123!
SEED_COLLEGE_A_USERNAME=dr-hn-national-college
SEED_COLLEGE_A_EMAIL=college-a@example.com
SEED_COLLEGE_B_USERNAME=national-college-jayanagar
SEED_COLLEGE_B_EMAIL=college-b@example.com
SEED_COLLEGE_C_USERNAME=national-pu-college
SEED_COLLEGE_C_EMAIL=college-c@example.com

# Firebase Cloud Messaging (for web push + dual notifications)
# Download service account JSON from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key_with_escaped_newlines
FIREBASE_DATABASE_URL=https://your_firebase_project_id.firebaseio.com
